APP_NAME="ERP SaaS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=America/Sao_Paulo
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

# ─── Multi-tenancy ─────────────────────────────────────────────────────────
CENTRAL_DOMAIN=localhost
APP_DOMAIN_BASE=erpsaas.com.br

# Super-admin inicial
ADMIN_EMAIL=admin@erpsaas.com.br
ADMIN_PASSWORD=MudarEstaSenha123
TENANT_DB_PREFIX=tenant_

# ─── Banco de dados principal (landlord) ──────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=erp_landlord
DB_USERNAME=erp
DB_PASSWORD=secret
DB_ROOT_PASSWORD=secret

# ─── Cache & Sessão ───────────────────────────────────────────────────────
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=480
SESSION_ENCRYPT=true
QUEUE_CONNECTION=redis
BROADCAST_DRIVER=redis

# ─── Redis ────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# ─── Mail ─────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@erpsaas.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Storage (S3 / MinIO) ─────────────────────────────────────────────────
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=erp-docs
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# ─── Fiscal — SEFAZ ───────────────────────────────────────────────────────
SEFAZ_AMBIENTE=2
# 1 = Produção | 2 = Homologação
SEFAZ_TIMEOUT=60
SEFAZ_RETRY=3

# CT-e
CTE_SEFAZ_AMBIENTE=2
CTE_ANTT_ENDPOINT=https://ws.antt.gov.br/CIOT/ServicoCIOT.svc

# ─── Logging ──────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_STACK=daily
LOG_DAYS=30

# ─── Horizon ──────────────────────────────────────────────────────────────
HORIZON_MEMORY_LIMIT=512
HORIZON_PREFIX=erp_horizon

# ─── Scribe (docs API) ────────────────────────────────────────────────────
SCRIBE_AUTH_ENABLED=true

# ─── Pusher / Reverb (WebSocket) ──────────────────────────────────────────
BROADCAST_DRIVER=reverb
REVERB_APP_ID=erp-saas
REVERB_APP_KEY=local-key
REVERB_APP_SECRET=local-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
